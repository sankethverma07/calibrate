# ─── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Electron build artifacts ─────────────────────────────────
electron/dist/
electron/out/
electron-builder.yml.local
release/
*.AppImage
*.dmg
*.exe
*.deb
*.snap
*.rpm

# ─── Vite / web build ─────────────────────────────────────────
# `dist/` is ignored by default to keep server bundle (dist/index.cjs)
# and Vite-hashed assets (dist/public/assets/) out of the repo.
#
# BUT the renderer's hand-maintained source files actually live under
# dist/public/ (this is where Electron loads from via file://). They're
# treated as source, not output — so they need to be tracked explicitly.
dist/
!dist/public/
dist/public/*
!dist/public/index.html
!dist/public/welcome.html
!dist/public/runtime-env.js
!dist/public/supabase/
!dist/public/supabase/**
build/
.vite/
server/public/
vite.config.ts.*

# ─── Environment & secrets ─────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
.supabase/
supabase/.branches
supabase/.temp

# ─── IDE / editor ──────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
.zed/

# ─── OS junk ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs & temp ──────────────────────────────────────────────
*.log
logs/
tmp/
.cache/
*.tar.gz

# ─── Local databases ──────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ─── Calibrate-specific user data ──────────────────────────────
# Never commit user mood history, presets, or local Supabase dumps
calibrate-userdata/
*.session.dump

# ─── Misc ─────────────────────────────────────────────────────
coverage/
.nyc_output/
*.tsbuildinfo
