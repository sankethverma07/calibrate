# ─── Calibrate · environment configuration ────────────────────
# Copy this file to `.env` and fill in your Supabase credentials.
# Without these, Calibrate runs fully local with no cross-device sync.

# Public Supabase URL (e.g. https://abcd1234.supabase.co)
VITE_SUPABASE_URL=

# Public anon key (safe to ship in client; RLS gates the data)
VITE_SUPABASE_ANON_KEY=

# Optional: only set if you want the desktop app to identify which
# device it's running on in profile metadata. Defaults to OS hostname.
# CALIBRATE_DEVICE_NAME=
